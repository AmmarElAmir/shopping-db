NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-side only (no NEXT_PUBLIC_ prefix) — powers the manual "Process now"
# button on the Bulk queue page. Fires the same routine your scheduled cron
# check calls.
ROUTINE_TRIGGER_URL=https://api.anthropic.com/v1/claude_code/routines/YOUR-ROUTINE-ID/fire
ROUTINE_TRIGGER_TOKEN=your-routine-trigger-token
